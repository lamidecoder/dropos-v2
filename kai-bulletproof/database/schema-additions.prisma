// ============================================================
// Add to backend/prisma/schema.prisma
// Model for database-backed refresh tokens
// ============================================================

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

