{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (ts-node-dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/backend/node_modules/.bin/ts-node-dev",
      "runtimeArgs": ["--respawn", "--transpile-only", "src/server.ts"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "sourceMaps": true,
      "console": "integratedTerminal"
    }
  ]
}
