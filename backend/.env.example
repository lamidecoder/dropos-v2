# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/dropos_db?schema=public"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Nodemailer) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="DropOS <noreply@dropos.io>"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Paystack ────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Flutterwave ─────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Platform Config ─────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
PLATFORM_NAME=DropOS
PLATFORM_URL=https://dropos.io

# ─── Cloudinary (Image Uploads) ──────────────────────────────
# Get FREE credentials at https://cloudinary.com → Dashboard
# Leave as "demo" during development — images save locally instead
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo
CLOUDINARY_API_SECRET=demo

# ─── File Upload ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── Subscription (Stripe) ────────────────────────────────────────────────────
# Get at https://dashboard.stripe.com → Developers → API Keys
# REPLACE with real keys when going live
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Plan Price IDs from Stripe Dashboard (create products + prices there)
STRIPE_PRO_MONTHLY_PRICE_ID=price_placeholder
STRIPE_PRO_YEARLY_PRICE_ID=price_placeholder
STRIPE_ADVANCED_MONTHLY_PRICE_ID=price_placeholder
STRIPE_ADVANCED_YEARLY_PRICE_ID=price_placeholder

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA → generate App Password → use here
# REPLACE with real values when going live
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="DropOS <noreply@dropos.io>"

# ─── Platform ────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ─── Twilio (SMS + WhatsApp) ──────────────────────────────────────────────────
# Get credentials at https://console.twilio.com
# Leave as "placeholder" during development — messages log to console instead
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder

# Your Twilio phone number (E.164 format, e.g. +12015551234)
TWILIO_PHONE_NUMBER=+12015551234

# WhatsApp sender — use Twilio Sandbox in dev, approved number in production
# Sandbox default: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:push@yourdomain.com

# Frontend (Next.js)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-your_key_here
